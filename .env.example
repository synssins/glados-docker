# .env.example — Docker Compose environment variable placeholders
# Copy to .env and fill in values. .env is gitignored.

# Home Assistant
HA_URL=http://YOUR_HA_IP:8123
HA_TOKEN=YOUR_LONG_LIVED_HA_TOKEN

# Snyk (token stored as GitHub Secret — SNYK_TOKEN)
# Org ID is hardcoded in .github/workflows/snyk.yml
SNYK_TOKEN=YOUR_SNYK_TOKEN

# Discord (optional)
DISCORD_BOT_TOKEN=

# SSL / Let's Encrypt (DNS-01 challenge — no external ports required)
# DNS-01 validates ownership via a DNS TXT record. Your DNS provider must
# have an API that the ACME sidecar container can use to create/delete records.
# Supported by most major providers (Route53, Cloudflare, Azure DNS, etc.)
# See your chosen ACME client's documentation for provider-specific variables.
# The API token/key should be scoped to DNS TXT record create/delete only.
SSL_ENABLED=false
# DNS_PROVIDER=         # e.g. cloudflare, route53, azure, namecheap
# DNS_API_TOKEN=        # provider API token — scope to minimum DNS permissions
# ACME_EMAIL=           # email for Let's Encrypt expiry notifications
# ACME_DOMAIN=          # domain to issue cert for, e.g. glados.home.local
