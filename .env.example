# .env.example — Docker Compose environment variable placeholders
# Copy to .env and fill in values. .env is gitignored.

# ── External service URLs ─────────────────────────────────────────────
# GLaDOS is pure middleware — it calls these services but does not host them.
# Run them wherever you like (host-native, another compose stack, another
# machine) and point GLaDOS at the URL.
#
# Defaults assume host-native services on the same machine, reachable via
# host.docker.internal.

OLLAMA_URL=http://host.docker.internal:11434

# Optional: split autonomy / vision onto a separate Ollama instance (e.g.
# a dedicated GPU) so background tasks (Tier 2 disambiguator, persona
# rewriter, vision queries) don't compete with user-facing chat for
# compute. If left unset, both fall back to OLLAMA_URL — one Ollama
# serves everything. Uncomment + set to split.
# OLLAMA_AUTONOMY_URL=http://host.docker.internal:11436
# OLLAMA_VISION_URL=http://host.docker.internal:11435

SPEACHES_URL=http://host.docker.internal:8800
VISION_URL=http://host.docker.internal:8016

# Speaches model/voice configuration
# Set SPEACHES_TTS_MODEL to the model your speaches instance uses.
# Common values: hexgrad/Kokoro-82M (default), rhasspy/piper-voices
SPEACHES_TTS_MODEL=hexgrad/Kokoro-82M
SPEACHES_TIMEOUT=30

# ── Home Assistant ────────────────────────────────────────────────────
HA_URL=http://YOUR_HA_IP:8123
HA_TOKEN=YOUR_LONG_LIVED_HA_TOKEN

# ── Snyk (CI only) ────────────────────────────────────────────────────
# Token stored as GitHub Secret — SNYK_TOKEN
# Org ID is hardcoded in .github/workflows/snyk.yml
SNYK_TOKEN=YOUR_SNYK_TOKEN

# ── Discord (optional) ────────────────────────────────────────────────
DISCORD_BOT_TOKEN=

# ── Configuration > Logs page (optional) ──────────────────────────────
# To view container / ChromaDB stdout via the Logs page, the glados user
# needs to be in the host's docker group so it can access the bind-mounted
# /var/run/docker.sock. Set this to the GID from:
#    getent group docker   # → docker:x:<GID>:...
# Leave unset (or at 0) to disable the container/chromadb log sources;
# the audit source (audit.jsonl) still works without the docker socket.
# GLADOS_DOCKER_GID=989

# ── SSL / Let's Encrypt (DNS-01 challenge — no external ports required) ──
# DNS-01 validates ownership via a DNS TXT record. Your DNS provider must
# have an API that the ACME sidecar container can use to create/delete records.
# Supported by most major providers (Route53, Cloudflare, Azure DNS, etc.)
# The API token/key should be scoped to DNS TXT record create/delete only.
SSL_ENABLED=false
# DNS_PROVIDER=         # e.g. cloudflare, route53, azure, namecheap
# DNS_API_TOKEN=        # provider API token — scope to minimum DNS permissions
# ACME_EMAIL=           # email for Let's Encrypt expiry notifications
# ACME_DOMAIN=          # domain to issue cert for, e.g. glados.home.local
