# .env.example — Docker Compose environment variable placeholders
# Copy to .env and fill in values. .env is gitignored.

# Home Assistant
HA_URL=http://YOUR_HA_IP:8123
HA_TOKEN=YOUR_LONG_LIVED_HA_TOKEN

# Snyk (token stored as GitHub Secret — SNYK_TOKEN)
# Org ID is hardcoded in .github/workflows/snyk.yml
SNYK_TOKEN=YOUR_SNYK_TOKEN

# Discord (optional)
DISCORD_BOT_TOKEN=

# SSL / Let's Encrypt (DNS-01 via Cloudflare — no external ports required)
SSL_ENABLED=false
CLOUDFLARE_API_TOKEN=YOUR_CLOUDFLARE_DNS_EDIT_TOKEN
# Token scope required: Zone:DNS:Edit on target zone only
# Generate at: https://dash.cloudflare.com/profile/api-tokens
