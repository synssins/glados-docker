# .env.example — GLaDOS deploy environment variables.
# Copy to .env and edit. .env is gitignored.

# ── Required ──────────────────────────────────────────────────────────
# LLM endpoint (named for legacy reasons — anything OpenAI-compatible
# works: Ollama, OpenVINO Model Server, llama.cpp llama-server, vLLM, …).
# Production target on the operator deployment is OVMS + Qwen3-30B-A3B-int4
# on Intel Arc Pro B60.
OLLAMA_URL=http://host.docker.internal:11434

# ── Home Assistant (recommended — needed for device control / autonomy) ──
HA_URL=http://YOUR_HA_HOST:8123
HA_TOKEN=YOUR_LONG_LIVED_HA_TOKEN

# ── Optional ──────────────────────────────────────────────────────────

# Container system clock TZ; default UTC. Time-of-day INJECTION uses the
# IANA zone resolved by your weather coordinates (System → Time card)
# instead — TZ only affects log timestamps.
# TZ=America/Chicago

# Split autonomy / vision onto separate LLM endpoints. Leave unset to use
# OLLAMA_URL for everything.
# OLLAMA_AUTONOMY_URL=http://host.docker.internal:11436
# OLLAMA_VISION_URL=http://host.docker.internal:11435

# External vision service (image classification / camera analysis). If unset,
# vision features are simply unavailable; nothing else breaks.
# VISION_URL=http://host.docker.internal:8016

# Discord (optional bot integration)
# DISCORD_BOT_TOKEN=
# DISCORD_GUILD_ID=

# WebUI Logs page docker-socket access (optional; lets the Logs page tail
# the container's own stdout). Set to your host's docker GID:
#   Linux:        getent group docker | cut -d: -f3
# Leave unset (or 0) if you don't need the Logs page's container source.
# GLADOS_DOCKER_GID=988

# Force HTTP→HTTPS redirect on a separate port (default disabled; HTTPS is on 8052).
# WEBUI_HTTP_REDIRECT_PORT=8053

# Loopback-only plain-HTTP port for in-container callers (TTS / STT /
# api_wrapper). Bound to 127.0.0.1 — never reachable from the LAN.
# Default 18015 is fine; override only on a port collision.
# GLADOS_INTERNAL_API_PORT=18015

# MCP plugin runtime master toggle. Set false to skip plugin discovery
# + spawn at engine startup; the WebUI Plugins panel renders an
# off-state notice. Read once at boot — flipping requires a restart.
# GLADOS_PLUGINS_ENABLED=true

# RECOVERY ONLY. Set to 1 to disable ALL auth checks (bright-red banner
# in the UI). Use only when the admin password is lost, then remove it
# and restart. Never leave set in a running deployment.
# GLADOS_AUTH_BYPASS=1

# CI only — do not set in deploy environment
# SNYK_TOKEN=
