# Secrets and local config — NEVER commit these
*.env
.env.*
!.env.example
config.local.yaml
config.local.yml
configs/*.local.yaml
configs/*.local.yml
# Operator-filled config files (contain HA tokens, PII, persona
# details, DNS tokens, Discord bot tokens, MQTT passwords, ...).
# The WebUI is the authoritative source of truth for these values;
# env is only a boot seed when the YAML is missing the field. Keep
# them local-only, never committed.
configs/config.yaml
configs/glados_config.yaml
configs/global.yaml
configs/services.yaml
configs/personality.yaml
configs/audio.yaml
configs/speakers.yaml
configs/memory.yaml
configs/observer.yaml
configs/discord.yaml
configs/mqtt.yaml
configs/hub75.yaml
configs/robots.yaml
configs/test_harness.yaml
configs/tts_pronunciation.yaml
configs/attitudes.json
configs/user_preferences.yaml
configs/disambiguation.yaml
configs/emotion_config.yaml
configs/announcements.yaml

# Generated by CI for Snyk scanning — not a source artifact
requirements.txt

# Live harness report — one-run artifact, regenerated on demand
tests/live_harness_report.txt

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/

# Docker local overrides
docker-compose.override.yml

# Logs
logs/
*.log

# Data and models — too large for git, host-mounted volumes
data/
# `models/` is gitignored by default, but models/TTS/ and models/ASR/
# are exceptions: the GLaDOS voice + ONNX phonemizer + CTC transcriber
# + Silero VAD are bundled in the image so the container is
# self-contained (tracked via Git LFS — see .gitattributes). BGE is
# fetched at build time, not committed.
models/*
!models/TTS/
!models/ASR/
models/TTS/bge-*
audio_files/

# Certs — secrets
certs/
*.pem
*.key
*.crt

# Other credential files — never commit
cloudflare.ini
*.secret
*.secrets
*.token
secrets/
.secrets/
id_rsa
id_ed25519
id_ecdsa
*.ppk
credentials.json
service-account*.json

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Claude Code — session-local launch config (may reference local paths/ports)
.claude/

# Dev-only WebUI scratch dirs written by tests/dev_webui.py + Playwright fixtures
tests/.tmp-glados-data/
tests/.playwright-report/
tests/.playwright-trace/

# Snyk — the .snyk suppression file SHOULD be committed when it exists.
# Nothing to ignore here; suppressions are a reviewable part of the repo.

# Git worktrees for isolated feature work (subagent-driven development).
.worktrees/

# Superpowers brainstorm session artifacts
.superpowers/
