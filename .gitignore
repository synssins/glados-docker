# Secrets and local config — NEVER commit these
*.env
.env.*
!.env.example
config.local.yaml
config.local.yml
configs/*.local.yaml
configs/*.local.yml
# Operator-filled config files (contain HA tokens, PII, persona details)
configs/config.yaml
configs/glados_config.yaml

# Generated by CI for Snyk scanning — not a source artifact
requirements.txt

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/

# Docker local overrides
docker-compose.override.yml

# Logs
logs/
*.log

# Data and models — too large for git, host-mounted volumes
data/
models/
audio_files/

# Certs — secrets
certs/
*.pem
*.key
*.crt

# Other credential files — never commit
cloudflare.ini
*.secret
*.secrets
*.token
secrets/
.secrets/
id_rsa
id_ed25519
id_ecdsa
*.ppk
credentials.json
service-account*.json

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Claude Code — session-local launch config (may reference local paths/ports)
.claude/

# Dev-only WebUI scratch dirs written by tests/dev_webui.py + Playwright fixtures
tests/.tmp-glados-data/
tests/.playwright-report/
tests/.playwright-trace/

# Snyk — the .snyk suppression file SHOULD be committed when it exists.
# Nothing to ignore here; suppressions are a reviewable part of the repo.
